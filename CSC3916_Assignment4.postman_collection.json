          "raw": "{{base_url}}/reviews",
          "host": ["{{base_url}}"],
          "path": ["reviews"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
