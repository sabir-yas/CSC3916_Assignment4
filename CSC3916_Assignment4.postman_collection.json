      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Returns array of matching movies', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.above(0);",
              "});",
              "pm.test('Results contain The Matrix (partial title match)', function () {",
              "    var json = pm.response.json();",
              "    var titles = json.map(function(m) { return m.title; });",
              "    pm.expect(titles).to.include('The Matrix');",
              "});",
              "pm.test('Results have avgRating and reviews fields', function () {",
              "    var json = pm.response.json();",
              "    json.forEach(function(movie) {",
              "        pm.expect(movie).to.have.property('avgRating');",
              "        pm.expect(movie).to.have.property('reviews');",
              "    });",
