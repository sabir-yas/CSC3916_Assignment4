    {
      "name": "4. GET All Movies (no reviews param)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/movies",
          "host": ["{{base_url}}"],
          "path": ["movies"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array with at least 5 movies', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.at.least(5);",
              "});",
              "pm.test('Each movie has required fields including imageUrl', function () {",
              "    var json = pm.response.json();",
              "    json.forEach(function(movie) {",
              "        pm.expect(movie).to.have.property('title');",
              "        pm.expect(movie).to.have.property('releaseDate');",
              "        pm.expect(movie).to.have.property('genre');",
              "        pm.expect(movie).to.have.property('actors');",
              "        pm.expect(movie).to.have.property('imageUrl');",
              "    });",
              "    pm.collectionVariables.set('movieId', json[0]._id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. GET All Movies with reviews=true (sorted by rating)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/movies?reviews=true",
          "host": ["{{base_url}}"],
          "path": ["movies"],
          "query": [
            { "key": "reviews", "value": "true" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Each movie has reviews array and avgRating', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "    json.forEach(function(movie) {",
              "        pm.expect(movie).to.have.property('reviews');",
              "        pm.expect(movie.reviews).to.be.an('array');",
              "        pm.expect(movie).to.have.property('avgRating');",
              "    });",
              "});",
              "pm.test('Movies are sorted by avgRating descending', function () {",
              "    var json = pm.response.json();",
              "    for (var i = 0; i < json.length - 1; i++) {",
              "        var curr = json[i].avgRating || 0;",
              "        var next = json[i+1].avgRating || 0;",
              "        pm.expect(curr).to.be.at.least(next);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. GET Movie by ID with reviews=true",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "{{token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/movies/{{movieId}}?reviews=true",
          "host": ["{{base_url}}"],
          "path": ["movies", "{{movieId}}"],
          "query": [
            { "key": "reviews", "value": "true" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Movie has all required fields', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('title');",
              "    pm.expect(json).to.have.property('imageUrl');",
              "    pm.expect(json).to.have.property('actors');",
              "    pm.expect(json).to.have.property('avgRating');",
              "    pm.expect(json).to.have.property('reviews');",
              "    pm.expect(json.reviews).to.be.an('array');",
              "});",
              "pm.test('Reviews contain username, rating, and review text', function () {",
              "    var json = pm.response.json();",
              "    json.reviews.forEach(function(r) {",
              "        pm.expect(r).to.have.property('username');",
              "        pm.expect(r).to.have.property('rating');",
              "        pm.expect(r).to.have.property('review');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
