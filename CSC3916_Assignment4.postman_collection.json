    {
      "name": "1. Sign Up",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"username\": \"testuser@test.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/signup",
          "host": ["{{base_url}}"],
          "path": ["signup"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Signup successful or user already exists', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('success');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Sign In (auto-saves JWT token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"testuser@test.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/signin",
          "host": ["{{base_url}}"],
          "path": ["signin"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has success: true', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.success).to.eql(true);",
              "});",
              "pm.test('JWT token is present and auto-saved', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('token');",
              "    pm.expect(json.token).to.include('JWT ');",
              "    pm.collectionVariables.set('token', json.token);",
              "    console.log('Token saved: ' + json.token.substring(0, 30) + '...');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
