  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://csc3916-assignment4-5qd5.onrender.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "movieId",
      "value": "69b3aafdc21231574801fe53",
